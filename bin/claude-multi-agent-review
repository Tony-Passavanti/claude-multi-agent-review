#!/usr/bin/env sh
# Entry point for the pre-push hook.
#
# .git/hooks/pre-push is symlinked to (or invokes) this script. We resolve the
# install directory, then hand off to the Python orchestrator. Stdin (the
# pre-push ref lines) flows through unchanged; argv ($1 = remote name, $2 =
# remote URL) is forwarded.

set -eu

# Resolve the directory this script lives in, following symlinks.
SCRIPT_PATH="$0"
while [ -L "$SCRIPT_PATH" ]; do
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  case "$LINK_TARGET" in
    /*) SCRIPT_PATH="$LINK_TARGET" ;;
    *)  SCRIPT_PATH="$(dirname "$SCRIPT_PATH")/$LINK_TARGET" ;;
  esac
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
INSTALL_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Resolve a Python 3 interpreter. Honor the env override if set; otherwise
# try `python3` (Unix convention) and fall back to `python` (Windows install
# convention, where `python3` is often a Microsoft Store redirect stub that
# fails with a non-zero exit). Error clearly if neither works.
PYTHON="${CLAUDE_MULTI_AGENT_REVIEW_PYTHON:-}"
if [ -z "$PYTHON" ]; then
  if python3 --version >/dev/null 2>&1; then
    PYTHON=python3
  elif python --version >/dev/null 2>&1; then
    PYTHON=python
  else
    echo "claude-multi-agent-review: no working python found on PATH" >&2
    echo "Set CLAUDE_MULTI_AGENT_REVIEW_PYTHON to the python binary path." >&2
    exit 2
  fi
fi

# Hand off to the Python orchestrator. Two flags work together to make
# this safe when invoked from a consuming repo that has its own `src/`
# package (extremely common — the standard "src layout"):
#
#   `-P`  (Python 3.11+) tells Python NOT to prepend a "potentially
#         unsafe path" (cwd for `-m`) to sys.path. Without this, cwd
#         would be searched before PYTHONPATH and the consuming repo's
#         `src/` would shadow ours.
#
#   PYTHONPATH=INSTALL_ROOT adds the install location to sys.path so
#         `python -m src` finds OUR `src/` package via the explicit
#         path rather than via cwd.
#
# Do NOT cd here: __main__.py reads `Path.cwd()` as repo_root, which
# is the consuming repo (what git invoked us from). cwd-as-sys-path
# is what we're suppressing; cwd-as-process-state is what we need.
PYTHONPATH="$INSTALL_ROOT${PYTHONPATH:+:$PYTHONPATH}" \
    exec "$PYTHON" -P -m src --install-root "$INSTALL_ROOT" "$@"
